# === Backend (локальный запуск: npm run start) ===
BOT_TOKEN=123456:your-telegram-bot-token
PORT=8080
PUBLIC_URL=https://your-public-url.example.com
BOT_WEB_APP_URL=https://tttoeonl.netlify.app
DATABASE_URL=postgres://user:password@localhost:5432/tictactoe
PGSSL=disable
CORS_ORIGINS=https://*.netlify.app

# === Frontend (Vite, встраивается при сборке) ===
# Для Netlify-деплоя оставьте пустыми: клиент будет ходить на свой же origin
# и использовать HTTP-поллинг вместо WebSocket.
VITE_API_BASE_URL=
VITE_WS_URL=
